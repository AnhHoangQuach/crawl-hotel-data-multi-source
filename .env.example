# --- Server ---
# HOST=0.0.0.0
# PORT=8000
# OUTPUT_DIR=output

# --- RapidAPI ---
# Shared key for both the TripAdvisor and Booking.com providers
# (get one at https://rapidapi.com/ after subscribing to the relevant API).
RAPIDAPI_KEY=

# Optional: point at a different RapidAPI product than the defaults
# (tripadvisor-scraper / Booking-com15). See app/infrastructure/config.py
# for the full list of overridable settings.
# TRIPADVISOR_RAPIDAPI_HOST=tripadvisor-scraper.p.rapidapi.com
# TRIPADVISOR_SEARCH_PATH=/hotels/search
# TRIPADVISOR_DETAILS_PATH=/hotels/detail

# BOOKING_RAPIDAPI_HOST=booking-com15.p.rapidapi.com
# BOOKING_SEARCH_DESTINATION_PATH=/api/v1/hotels/searchDestination
# BOOKING_SEARCH_HOTELS_PATH=/api/v1/hotels/searchHotels
# BOOKING_DETAILS_PATH=/api/v1/hotels/getHotelDetails
# BOOKING_CURRENCY_CODE=VND
